# This files contains required params for .env

# ── Mode ─────────────────────────────────────────────────────
# true  = use local Docker database
# false = use production Railway database
LOCAL_MODE=true

# ── Local database (Docker) ───────────────────────────────────
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=
LOCAL_DB_USER=
LOCAL_DB_PASSWORD=

# ── Production database (Railway) ────────────────────────────
PRODUCTION_DB_HOST=
PRODUCTION_DB_PORT=
PRODUCTION_DB_NAME=
PRODUCTION_DB_USER=
PRODUCTION_DB_PASSWORD=

# ── Backend ───────────────────────────────────────────────────
KTOR_PORT=8080

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=
JWT_ISSUER=readysetgo
JWT_AUDIENCE=readysetgo-users
JWT_EXPIRATION_MS=86400000

# ── Railway deployment ────────────────────────────────────────
RAILWAY_TOKEN=
RAILWAY_STAGING_SERVICE_ID=
RAILWAY_STAGING_ENVIRONMENT_ID=
RAILWAY_PRODUCTION_SERVICE_ID=
RAILWAY_PRODUCTION_ENVIRONMENT_ID=